{
  "name": "OLTP Workload",
  "description": "Standard Sysbench-like OLTP benchmark",
  "schema": {
    "tables": 10,
    "table_size": 100000
  },
  "queries": [
    {
      "sql": "SELECT * FROM {table} WHERE id = {id}",
      "weight": 0.4,
      "description": "Point select (primary key lookup)"
    },
    {
      "sql": "SELECT * FROM {table} WHERE id BETWEEN {low} AND {high} LIMIT 100",
      "weight": 0.16,
      "description": "Small range scan"
    },
    {
      "sql": "SELECT id, k FROM {table} WHERE k = {k_val} LIMIT 10",
      "weight": 0.12,
      "description": "Index scan on secondary column"
    },
    {
      "sql": "SELECT id, k FROM {table} WHERE id BETWEEN {low} AND {high} ORDER BY k LIMIT 20",
      "weight": 0.12,
      "description": "Range scan with ordering"
    },
    {
      "sql": "UPDATE {table} SET k = k + 1 WHERE id = {id}",
      "weight": 0.14,
      "description": "Simple UPDATE (primary key)"
    },
    {
      "sql": "UPDATE {table} SET c = 'updated' WHERE k = {k_val}",
      "weight": 0.03,
      "description": "UPDATE with secondary index"
    },
    {
      "sql": "DELETE FROM {table} WHERE id = {id}",
      "weight": 0.015,
      "description": "DELETE row"
    },
    {
      "sql": "INSERT INTO {table} (id, k, c, pad) SELECT MAX(id)+1, {k_val}, 'reinserted', 'x' FROM {table}",
      "weight": 0.015,
      "description": "INSERT row"
    }
  ]
}
