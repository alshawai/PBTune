# ============================================================================
# Environment Configuration Template
# ============================================================================
# 
# Copy this file to .env and configure with your PostgreSQL credentials:
#   cp .env.example .env
#
# SECURITY WARNING: Never commit the .env file to version control!
# The .env file is already included in .gitignore.
#
# See docs/ENVIRONMENT_SETUP.md for detailed configuration instructions.
# ============================================================================

# PostgreSQL Database Configuration
# ----------------------------------------------------------------------------
# Template database for schema initialization and PBT optimization testing
# The PBT system creates isolated instances for each worker using these
# credentials as the template.

# Database username (default: postgres)
DB_USER=postgres

# Database password (REQUIRED - set your actual password)
DB_PASSWORD=your_secure_password_here

# Database host (default: localhost for local PostgreSQL)
DB_HOST=localhost

# Database port (default: 5432 for PostgreSQL)
DB_PORT=5432

# Database name (default: test_dataset)
# This database should contain your workload schema (e.g., sbtest1 table)
DB_NAME=test_dataset

# ============================================================================
# NOTES
# ============================================================================
#
# 1. REQUIRED: DB_PASSWORD must be set before running the tuner
# 2. The template database (DB_NAME) is used to initialize worker instances
# 3. Worker instances run on ports DB_PORT+1, DB_PORT+2, etc.
# 4. Ensure PostgreSQL is installed and pg_ctl/initdb are in PATH
# 5. For production use, use strong passwords and secure credential storage
#
# ============================================================================

